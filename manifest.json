{
  "manifest_version": 3,
  "name": "EdgeGenius - 脚本管理器",
  "version": "2.6.0",
  "description": "一个集成了 AI 辅助编程的 Tampermonkey 风格用户脚本管理器。",
  "action": {
    "default_popup": "index.html",
    "default_title": "EdgeGenius 脚本管理器"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}